{
  "name": "@biip-finansai/api",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/runner.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node ../../node_modules/moleculer/bin/moleculer-runner.js --config dist/moleculer.config.js \"dist/services/**/*.service.js\"",
    "test": "jest --passWithNoTests",
    "lint": "eslint 'src/**/*.ts'",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:migrate": "knex migrate:latest --knexfile src/database/knexfile.ts",
    "db:seed": "knex seed:run --knexfile src/database/knexfile.ts"
  },
  "dependencies": {
    "@biip-finansai/shared": "*",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7",
    "ioredis": "^5.4.1",
    "knex": "^3.1.0",
    "moleculer": "^0.14.35",
    "moleculer-db": "^0.8.27",
    "moleculer-web": "^0.10.7",
    "objection": "^3.1.5",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
